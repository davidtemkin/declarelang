#!/bin/sh
# Before each commit: (0) regenerate the COMMITTED pre-warm cache (bundles/cache/)
# from the current sources — so the curated precompiled artifacts stay in step
# with the tree; each is self-validating, so a skipped regen only costs the
# compiler-free fast path, never correctness (tools/prewarm.mjs). (1) rebuild any
# STALE platform bundle — stamp-version calls tools/bundle-freshness.mjs first, so
# a commit cannot ship a bundles artifact older than its inputs; (2) stamp the
# cache-busting BUILD_ID so every deploy carries a build id that reflects the
# current platform (runtime + bundles + web client + SW + committed cache).
# Idempotent: nothing relevant moved → no regen, no rebuild, no restamp, no churn.
#
# Order matters: prewarm writes bundles/cache/ BEFORE stamp-version hashes bundles/
# into the BUILD_ID, so a committed-artifact change rebumps the id (dropping the SW
# cache bucket on deploy).
#
# Committed + shared (not the per-clone .git/hooks/ copy). `npm install` wires it up via the
# package.json "prepare" script; to activate by hand: git config core.hooksPath tools/hooks
node tools/prewarm.mjs || exit 0
node tools/stamp-version.mjs || exit 0
git add service-worker.js bundles 2>/dev/null
exit 0
