# dependencies
node_modules/

# TypeScript incremental build cache
*.tsbuildinfo

# server /prod/ on-demand build cache (regenerated per request; the committed prebuilt/ is the real artifact).
# one dir per backend/variant — .prod-cache/, .prod-cache-canvas/, … — all regenerated, none committed.
.prod-cache*/

# porting scratch area (OL5 references + comparison goldens): local-only, deletable
workshop/

# eval run artifacts: per-run transcripts/sandboxes/metrics are local — only the
# generated evals/RESULTS.md scoreboard (and the tasks) are committed.
evals/runs/

# internal dev tools compiled locally: the .swift source is tracked, the built
# binary is a per-machine build artifact (macOS-only, regenerated with swiftc).
tools/internal/pointer

# your own scratch apps: the getting-started home (operational:getting-started,
# guide:loop) is yours, local, and never part of the distro — the committed
# examples live in apps/.
my-apps/

# misc
*.log
.DS_Store

# NOTE: dist/ is intentionally committed (per-area compiler/dist, runtime/dist) so the
# whole tree hosts and runs as-is, no build step — the OpenLaszlo distribution model.

# the dev supervisor's per-port reload handle (server/dev.mjs; `npm run build:dev` signals it)
server/.dev-reload.*.pid
