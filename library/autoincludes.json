{
  "$provide": [
    {
      "class": "FocusRing",
      "when": {
        "baseUsed": "Control"
      },
      "comment": "the traveling focus indicator — provided with the component library"
    },
    {
      "class": "Tooltip",
      "when": {
        "attributeUsed": "tip",
        "onBase": "View"
      },
      "comment": "the tooltip singleton — provided with the component library (tip = attribute)"
    }
  ],
  "Bar": "bar.declare",
  "Control": "control.declare",
  "Checkbox": "checkbox.declare",
  "Button": "button.declare",
  "Switch": "switch.declare",
  "Slider": "slider.declare",
  "RadioGroup": "radiogroup.declare",
  "Radio": "radiogroup.declare",
  "Field": "field.declare",
  "SearchField": "searchfield.declare",
  "ProgressBar": "progressbar.declare",
  "FocusRing": "focusring.declare",
  "TabSlider": "tabslider.declare",
  "Tab": "tabslider.declare",
  "Tooltip": "tooltip.declare",
  "Menu": "menu.declare",
  "MenuBar": "menubar.declare",
  "Dialog": "dialog.declare",
  "AppIsland": "appisland.declare"
}
